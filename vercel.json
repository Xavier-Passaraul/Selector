{
  "version": 2,
  "buildCommand": "npm install",
  "functions": {
    "api/**/*.js": {
      "memory": 128,
      "maxDuration": 60
    }
  },
  "env": {
    "DATABASE_URL": "@database_url",
    "JWT_SECRET": "@jwt_secret"
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
